# Optional overrides for agent live-test helper scripts.
# Copy to .env.live-test and adjust for your machine:
#
#   cp .env.live-test.example .env.live-test

# Agent live-test starter wiring
LIVE_TEST_STARTER_PORT=8080
LIVE_TEST_SIGNALING_WS_URL=ws://127.0.0.1:8080/ws
LIVE_TEST_AGENT_BUNDLE_PATH=./dist/agent.js

# Optional default values for the browser page inputs
LIVE_TEST_SESSION_ID=local-dev
LIVE_TEST_ROOM_ID=local-dev
LIVE_TEST_JOIN_TOKEN=local-dev

# Optional: voice provider overrides passed to the starter process.
# Defaults are local-sherpa (if unset).
#  more info on the VOICE vendor settings here: https://github.com/akirilyuk/node-webrtc-rust#stttts-vendors-and-config
# VOICE_STT_PROVIDER=local-sherpa
# VOICE_TTS_PROVIDER=local-sherpa

# Local-sherpa model paths (absolute paths recommended).
# You can generate these automatically via:
#   npm run live-test:models
# SHERPA_STT_MODEL_PATH=/absolute/path/to/agent/.models/sherpa-onnx-streaming-zipformer-en-kroko-2025-08-06
# SHERPA_TTS_MODEL_PATH=/absolute/path/to/agent/.models/vits-piper-en_US-amy-low
# SHERPA_STT_LANGUAGE=en
# SHERPA_TTS_SPEAKER=0

# Hosted provider API keys (only set what your selected providers need)
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ASSEMBLYAI_API_KEY=
# ELEVENLABS_API_KEY=
# CARTESIA_API_KEY=
# GOOGLE_API_KEY=
