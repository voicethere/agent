{
  "name": "@voicethere/agent",
  "version": "0.2.6",
  "description": "VoiceThere customer agent SDK — IPC types and runtime helpers for sandboxed child bundles",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js",
      "require": "./dist/runner.js",
      "default": "./dist/runner.js"
    },
    "./verify": {
      "types": "./dist/verify/run-verify.d.ts",
      "import": "./dist/verify/run-verify.js",
      "require": "./dist/verify/run-verify.js",
      "default": "./dist/verify/run-verify.js"
    }
  },
  "bin": "./dist/cli.js",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:lib": "tsc -p tsconfig.json && mkdir -p dist/sandbox && cp src/sandbox/loader-entry.js dist/sandbox/",
    "build:example": "node dist/cli.js build --entry examples/agent.ts --outfile dist/agent.js",
    "build": "npm run build:lib && npm run build:example",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:ci": "npm run typecheck && npm run build && npm run test && node scripts/ci/verify-package-exports.mjs",
    "verify:local": "npm run build && node ./dist/cli.js verify --no-build --bundle ./dist/agent.js",
    "verify:local:only": "node ./dist/cli.js verify --no-build --bundle ./dist/agent.js",
    "live-test:models": "bash ./scripts/select-sherpa-models.sh",
    "live-test:page": "bash ./scripts/live-test-page.sh",
    "live-test:starter": "bash ./scripts/live-test-starter.sh",
    "live-test:stack": "npm run live-test:stack:echo",
    "live-test:stack:echo": "LIVE_TEST_AGENT_ENTRY=examples/agent.ts LIVE_TEST_PAGE_PATH=/examples/live-test/index.html LIVE_TEST_SESSION_MODE=voice bash ./scripts/live-test-stack.sh",
    "live-test:stack:game": "LIVE_TEST_AGENT_ENTRY=templates/game-sync.ts LIVE_TEST_PAGE_PATH=/examples/live-test/game-sync.html LIVE_TEST_SESSION_MODE=data-only bash ./scripts/live-test-stack.sh",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voicethere/agent.git"
  },
  "bugs": {
    "url": "https://github.com/voicethere/agent/issues"
  },
  "homepage": "https://github.com/voicethere/agent#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "voicethere",
    "voice-agent",
    "webrtc",
    "sandbox"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "esbuild": "^0.25.12"
  },
  "peerDependencies": {
    "@node-webrtc-rust/sdk": ">=0.6.5"
  },
  "devDependencies": {
    "@node-webrtc-rust/helpers": "0.6.5",
    "@node-webrtc-rust/sdk": "0.6.5",
    "@node-webrtc-rust/signaling": "0.6.5",
    "@types/node": "^22.10.0",
    "http-server": "^14.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
